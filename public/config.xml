<?xml version="1.0" encoding="UTF-8"?>
<widget xmlns="http://www.w3.org/ns/widgets"
  xmlns:tizen="http://tizen.org/ns/widgets"
  id="https://my-home-media-server.local/tizen"
  version="0.6.1"
  viewmodes="maximized">
  <tizen:application id="MHMServer1.MyHomeMediaServer" package="MHMServer1" required_version="5.5" />
  <tizen:profile name="tv-samsung" />
  <name>My Home Media Server</name>
  <description>Opinionated local media server for responsive Samsung TV browsing and playback.</description>
  <icon src="tizen-icon.png" />
  <content src="tv.html" />
  <access origin="*" subdomains="true" />
  <tizen:privilege name="http://tizen.org/privilege/internet" />
  <tizen:privilege name="http://tizen.org/privilege/tv.inputdevice" />
  <tizen:privilege name="http://developer.samsung.com/privilege/avplay" />
  <tizen:privilege name="http://developer.samsung.com/privilege/productinfo" />
  <tizen:setting
    background-support="disable"
    context-menu="disable"
    encryption="disable"
    install-location="auto"
    screen-orientation="landscape" />
</widget>
